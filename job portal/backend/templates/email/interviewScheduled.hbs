<div style="font-family: Arial, sans-serif; max-width: 700px; margin: 0 auto; padding: 20px; background: #f9fafb;">
  <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <h2 style="color: #111827; margin: 0 0 16px 0;">🎯 Interview Scheduled!</h2>
    <p>Hi {{studentName}},</p>
    <p>
      Congratulations! You’ve been invited to an interview for:
      <strong>{{jobTitle}}</strong> at <strong>{{companyName}}</strong>.
    </p>

    <div style="background: #f0fdf4; border-left: 4px solid #10b981; padding: 16px; margin: 20px 0; border-radius: 0 6px 6px 0;">
      <p><strong>📅 Date:</strong> {{date}}</p>
      <p><strong>🕗 Time:</strong> {{time}}</p>
      <p><strong>📍 Type:</strong> {{interviewType}}</p>
      {{#if videoLink}}
        <p><strong>🔗 Video Link:</strong> <a href="{{videoLink}}" style="color: #ef4444;">{{videoLink}}</a></p>
      {{/if}}
      {{#if phoneNumber}}
        <p><strong>📞 Phone:</strong> {{phoneNumber}}</p>
      {{/if}}
      {{#if officeAddress}}
        <p><strong>🏢 Address:</strong> {{officeAddress}}</p>
      {{/if}}
    </div>

    <p>Please be ready 5 minutes before the scheduled time.</p>
    <p>
      <a href="{{frontendUrl}}/applications/{{applicationId}}" 
         style="background: #ef4444; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; display: inline-block; font-weight: bold;">
        View Interview Details
      </a>
    </p>

    <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 30px 0;" />
    <p style="font-size: 12px; color: #6b7280;">
      Need help? Reply to this email or contact support.
    </p>
  </div>
</div>