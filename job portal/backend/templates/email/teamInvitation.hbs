<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Team Invitation - {{companyName}}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px 8px 0 0;
            border-bottom: 3px solid #0066cc;
        }

        .content {
            padding: 24px;
            background: #fff;
            border: 1px solid #e0e0e0;
            border-top: none;
            border-radius: 0 0 8px 8px;
        }

        .credentials {
            background: #f8f9fa;
            padding: 16px;
            border-left: 4px solid #0066cc;
            margin: 20px 0;
        }

        .button {
            display: inline-block;
            padding: 12px 24px;
            background: #0066cc;
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
            margin: 20px 0;
        }

        .footer {
            text-align: center;
            font-size: 12px;
            color: #666;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
        }

        .warning {
            background: #fff3cd;
            border: 1px solid #ffc107;
            padding: 12px;
            border-radius: 4px;
            margin: 16px 0;
            font-size: 14px;
        }
    </style>
</head>

<body>
    <div class="header">
        <h2 style="margin: 0;">You have been added to {{companyName}}</h2>
    </div>
    <div class="content">
        <p>Hello {{firstName}},</p>
        <p>{{invitedBy}} has added you as a team member to <strong>{{companyName}}</strong> on our job portal.</p>

        <p><strong>Role:</strong> {{roleName}}</p>

        <div class="credentials">
            <p style="margin: 0 0 8px 0;"><strong>Your login credentials:</strong></p>
            <p style="margin: 4px 0;"><strong>Email:</strong> {{email}}</p>
            <p style="margin: 4px 0;"><strong>Password:</strong> {{temporaryPassword}}</p>
        </div>

        <div style="text-align: center;">
            <a href="{{loginUrl}}" class="button">Access Your Account</a>
        </div>

        <div class="warning">
            <strong>Security Notice:</strong> If you did not expect this invitation, please contact your administrator
            immediately. Do not share your credentials with anyone.
        </div>

        <p>If you have any questions, contact your administrator: {{adminEmail}}</p>
    </div>
    <div class="footer">
        <p>This invitation was sent to {{email}} because you were added as a team member at {{companyName}}.</p>
        <p>© {{year}} {{companyName}}. All rights reserved.</p>
    </div>
</body>

</html>